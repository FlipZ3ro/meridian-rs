# Meridian RS environment template
# Copy to `.env` for local development, or to `~/.meridian/.env` for the default runtime profile.
# Never commit real private keys or API keys.

# ── Safety ───────────────────────────────────────────────────────
# Keep true while testing. Live transaction submission should only be enabled intentionally.
DRY_RUN=true

# ── Wallet ───────────────────────────────────────────────────────
# You only need ONE wallet. The RECOMMENDED, safest option is to point
# WALLET_PRIVATE_KEY at your Solana CLI keypair FILE (the raw key never gets
# pasted into this file). Create one with the Solana CLI:
#   solana-keygen new --outfile ~/.config/solana/meridian.json
# then set the path (use forward slashes on Windows):
#   WALLET_PRIVATE_KEY=/home/you/.config/solana/meridian.json
# It also accepts a raw secret directly: a base58 string, or a [1,2,3,...] byte array.
WALLET_PRIVATE_KEY=

# Public wallet address (balance/position reads only). OPTIONAL — it is
# auto-derived from the keypair above when left empty. Set it only if you want
# to read a DIFFERENT address than the one that signs.
MERIDIAN_WALLET=

# ── RPC / Helius ─────────────────────────────────────────────────
# Original JS-compatible RPC env. Used by the Rust config loader.
RPC_URL=https://api.mainnet-beta.solana.com

# Preferred when using Helius.
HELIUS_RPC_URL=
HELIUS_API_KEY=

# ── LLM / OpenAI-compatible provider ─────────────────────────────
# OpenRouter example:
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Generic OpenAI-compatible fallback. If set, this is also accepted.
LLM_API_KEY=

# Model aliases are mapped into the Rust runtime config.
LLM_MODEL=openai/gpt-4o-mini
MANAGEMENT_MODEL=
SCREENING_MODEL=
GENERAL_MODEL=

# ── Runtime state / local services ───────────────────────────────
# Defaults to ~/.meridian when unset.
MERIDIAN_DATA_DIR=
# Optional override for the position state file only.
MERIDIAN_STATE_PATH=
# Web UI listener. Use 127.0.0.1 for local-only production deployments behind a tunnel/proxy.
MERIDIAN_WEB_ADDR=0.0.0.0:3000
# Operator log renderer: pretty (default) or plain (legacy bracketed logs).
MERIDIAN_LOG_STYLE=pretty
# Lightweight HTTP health endpoint port.
HEALTH_PORT=8080
# Duplicate-process guard lock file. Defaults to ~/.meridian/meridian.lock when unset.
MERIDIAN_LOCK_PATH=

# ── Optional integrations ────────────────────────────────────────
JUPITER_API_KEY=
JUPITER_REFERRAL_ACCOUNT=
JUPITER_REFERRAL_FEE_BPS=50
AGENT_MERIDIAN_API_URL=
PUBLIC_API_KEY=
LPAGENT_API_KEY=
# Optional Discord signal listener/importer compatibility. Keep tokens local and never commit values.
DISCORD_USER_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_IDS=
DISCORD_MIN_FEES_SOL=5
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
